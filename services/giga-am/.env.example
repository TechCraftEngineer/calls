# GigaAM Service Configuration

# Server
HOST=0.0.0.0
PORT=7860

# Model
MODEL_NAME=v3_e2e_rnnt

# HuggingFace Token (для pyannote моделей)
HF_TOKEN=

# Remote Diarization Service
SPEAKER_EMBEDDINGS_URL=http://speaker-embeddings:7860

# Diarization Settings
DIARIZATION_NUM_SPEAKERS=  # Точное количество спикеров (если известно)
DIARIZATION_MIN_SPEAKERS=  # Минимальное количество
DIARIZATION_MAX_SPEAKERS=  # Максимальное количество
DIARIZATION_MIN_SEGMENT_DURATION=0.5

# Audio Preprocessing
AUTO_RESAMPLE_ENABLED=true
TARGET_SAMPLE_RATE=16000

# Dual ASR + LLM Correction (оркестрация через Inngest)
ENABLE_DUAL_ASR_LLM_CORRECTION=true

# Inngest Connection (LLM настройки в Inngest, не здесь!)
INNGEST_API_URL=http://localhost:3001
INNGEST_EVENT_KEY=  # Опционально

# Alignment
ALIGNMENT_ENABLED=true

# Logging
LOG_LEVEL=INFO
