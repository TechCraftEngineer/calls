# GigaAM API Configuration Example

# Application
APP_NAME="GigaAM API"
APP_VERSION="1.0.1"
DEBUG=false

# Server
HOST="0.0.0.0"
PORT=7860

# Model
MODEL_NAME="v3_e2e_rnnt"

# File Upload
MAX_FILE_SIZE=104857600  # 100MB in bytes
ALLOWED_AUDIO_FORMATS=".mp3,.wav,.flac,.m4a,.aac,.ogg,.webm"

# Security
HF_TOKEN=""  # Hugging Face token for private models

# Logging
LOG_LEVEL="INFO"

# Timeouts
TRANSCRIPTION_TIMEOUT=900  # 15 minutes
SOURCE_DOWNLOAD_TIMEOUT=120
CALLBACK_TIMEOUT=20

# Pipeline Features
DIARIZATION_ENABLED=true
ALIGNMENT_ENABLED=true
LLM_CORRECTION_ENABLED=true
STRICT_CORRECTION_MODE=true

# Speaker Embeddings Service
SPEAKER_EMBEDDINGS_URL=""  # e.g., https://your-space.hf.space
SPEAKER_EMBEDDINGS_TIMEOUT=60

# Audio Preprocessing (автоматическое улучшение качества)
# Automatically resample audio to target sample rate if lower
AUTO_RESAMPLE_ENABLED=true

# Target sample rate for resampling in Hz (8000-48000)
# Recommended: 16000 for good diarization quality
TARGET_SAMPLE_RATE=16000

# Modern Clustering Settings (2024-2025 improvements)
# Base threshold for cosine distance clustering (0.1-0.9)
# Lower = stricter (fewer speakers), Higher = more lenient (more speakers)
CLUSTERING_BASE_THRESHOLD=0.40

# Minimum segment duration for reliable clustering in seconds (0.1-2.0)
# Shorter segments are filtered and reassigned after main clustering
CLUSTERING_MIN_SEGMENT_DURATION=0.3

# Weight of temporal proximity in clustering (0.0-0.5)
# Higher = more weight to time-adjacent segments being same speaker
CLUSTERING_TEMPORAL_WEIGHT=0.1

# Confidence threshold for final clustering (0.0-1.0)
CLUSTERING_CONFIDENCE_THRESHOLD=0.6

# Overlap Separation Settings (одновременная речь)
# Enable separation of overlapping speech (simultaneous speakers)
OVERLAP_SEPARATION_ENABLED=true

# Confidence threshold for overlap detection (0.0-1.0)
OVERLAP_CONFIDENCE_THRESHOLD=0.7

# Minimum overlap duration to process in seconds (0.1-5.0)
MIN_OVERLAP_DURATION=0.5

# Embedding similarity threshold for overlap speaker separation (0.0-1.0)
# Higher = stricter (only very similar speakers separated)
OVERLAP_EMBEDDING_SIMILARITY=0.6

# LLM Settings
LLM_API_URL=""
LLM_API_KEY=""
LLM_MODEL="gpt-4o-mini"
LLM_TIMEOUT=45

# Jobs
JOBS_DIR="temp/jobs"
MAX_PARALLEL_JOBS=1
JOB_TTL_HOURS=24
MAX_JOB_RETRIES=2

# Metrics
METRICS_HISTORY_SIZE=1000
SYSTEM_METRICS_INTERVAL=30  # seconds

# Cache
CACHE_MAX_SIZE=1000
CACHE_MAX_AGE_HOURS=24

# Concurrency
MODEL_WORKERS=2
MODEL_LOADING_TIMEOUT=600  # seconds

# Admin (for protected endpoints)
ADMIN_TOKEN=""  # Set a secure token for admin operations
ENABLE_CACHE_CLEAR=false
