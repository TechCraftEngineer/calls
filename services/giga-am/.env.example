# Hugging Face токен для доступа к pyannote/segmentation-3.0
# Получите токен на https://huggingface.co/settings/tokens
# Примите условия доступа: https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=your_token_here

# Таймаут распознавания в секундах (по умолчанию 900 = 15 минут)
TRANSCRIPTION_TIMEOUT=900

# Таймаут загрузки модели в секундах (по умолчанию 600 = 10 минут)
MODEL_LOADING_TIMEOUT=600
