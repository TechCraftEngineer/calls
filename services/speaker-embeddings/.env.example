# HuggingFace токен (опционально, только для не-community моделей)
# Для community модели токен НЕ требуется
# Получите токен на https://huggingface.co/settings/tokens
HF_TOKEN=

# Порт сервиса
PORT=7860

# Модель диаризации pyannote.audio
# Community версия работает без HF_TOKEN локально
PYANNOTE_DIARIZATION_MODEL=pyannote/speaker-diarization-community-1
