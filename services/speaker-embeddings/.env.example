# HuggingFace токен для доступа к pyannote моделям
# Получите токен на https://huggingface.co/settings/tokens
# Примите условия доступа: https://huggingface.co/pyannote/embedding
HF_TOKEN=

# Порт сервиса
PORT=7860

# Включить/выключить pyannote (1/0)
ENABLE_PYANNOTE=1

# Модель pyannote
PYANNOTE_MODEL=pyannote/embedding
