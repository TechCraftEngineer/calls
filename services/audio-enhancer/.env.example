# Audio Enhancer Configuration

# Настройки приложения
APP_NAME=Audio Enhancer
DEBUG=false
HOST=0.0.0.0
PORT=7860

# Ограничения файлов
MAX_FILE_SIZE=83886080  # 80MB в байтах
MAX_AUDIO_SECONDS=14400  # 4 часа

# Логирование
LOG_LEVEL=INFO

# HuggingFace токен для pyannote диаризации
# Получить токен: https://huggingface.co/settings/tokens
# Требуется для pyannote/speaker-diarization-3.1
HF_TOKEN=your_huggingface_token_here
