{
  "name": "@calls/root",
  "private": true,
  "engines": {
    "node": "^22.21.0",
    "bun": "^1.3.5"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "auth:generate": "bun --filter @calls/auth generate",
    "db:push": "turbo -F @calls/db push",
    "db:reset": "turbo -F @calls/db db:reset",
    "db:studio": "turbo -F @calls/db studio",
    "dev": "turbo watch dev --continue --concurrency 20",
    "dev:next": "turbo watch dev -F @calls/app...",
    "dev:backend": "bun --filter @calls/backend-server dev",
    "format": "biome format . --skip-parse-errors",
    "format:fix": "biome format --write . --skip-parse-errors",
    "lint": "biome lint . --skip-parse-errors",
    "lint:fix": "biome lint --write . --skip-parse-errors",
    "check": "biome check . --skip-parse-errors",
    "check:fix": "biome check --write . --skip-parse-errors",
    "lint:ws": "bunx sherif@latest",
    "postinstall": "bun lint:ws",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "test:e2e": "turbo -F @calls/e2e test",
    "test:e2e:ui": "turbo -F @calls/e2e test:ui",
    "test:e2e:auth": "turbo -F @calls/e2e test:auth",
    "generate-favicon": "bun run scripts/generate-favicon.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@turbo/gen": "^2.8.17",
    "ai": "^6.0.116",
    "to-ico": "^1.1.5",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ]
}
