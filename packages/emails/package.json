{
  "name": "@calls/emails",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "license": "MIT",
  "workspaces": [
    ".react-email"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**"
  ],
  "scripts": {
    "clean": "rm -rf *.tsbuildinfo .turbo dist",
    "dev": "bun with-env email dev -p 3002",
    "with-env": "bun run --env-file ../../.env",
    "typecheck": "tsc --noEmit",
    "build": "tsdown",
    "export": "email export"
  },
  "dependencies": {
    "@calls/config": "workspace:*",
    "@calls/tsconfig": "workspace:*",
    "@radix-ui/colors": "3.0.0",
    "@react-email/components": "1.0.10",
    "@tailwindcss/typography": "0.5.19",
    "nodemailer": "^8.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "5.2.10",
    "resend": "^6.9.4",
    "sharp": "^0.34.5",
    "tailwindcss": "4.2.2",
    "tailwindcss-animate": "1.0.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@react-email/preview-server": "5.2.10",
    "@types/node": "25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "tsdown": "^0.21.4",
    "typescript": "6.0.2"
  }
}
