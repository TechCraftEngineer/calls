# Inngest Jobs Service Configuration

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Dual ASR LLM Correction
# Использует стандартные настройки AI из @calls/config
# Настройте AI_PROVIDER, AI_MODEL и соответствующий API ключ
ENABLE_DUAL_ASR_LLM_CORRECTION=true

# GigaAM Configuration
# Таймаут для запросов транскрибации GigaAM в миллисекундах (по умолчанию 300000 = 5 минут)
GIGA_AM_TIMEOUT_MS=300000

# AI Provider (openai | openrouter | deepseek)
AI_PROVIDER=openrouter
AI_MODEL=openai/gpt-4o-mini

# API Keys (настройте нужный провайдер)
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-v1-...
DEEPSEEK_API_KEY=sk-...

# Database
DATABASE_URL=postgresql://...

# Other services
# (добавьте другие настройки по необходимости)
