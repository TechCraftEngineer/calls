# Inngest Jobs Service Configuration

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# LLM для Dual ASR Correction
ENABLE_DUAL_ASR_LLM_CORRECTION=true
DUAL_ASR_LLM_API_URL=https://api.openai.com/v1
DUAL_ASR_LLM_API_KEY=sk-...
DUAL_ASR_LLM_MODEL=gpt-4o-mini
DUAL_ASR_LLM_TIMEOUT=60

# Или используйте общие LLM настройки
LLM_API_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# Database
DATABASE_URL=postgresql://...

# Other services
# (добавьте другие настройки по необходимости)
