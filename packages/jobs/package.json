{
  "name": "@calls/jobs",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./hono": "./src/inngest-handler.ts",
    "./pbx/sync": "./src/pbx/sync.ts"
  },
  "scripts": {
    "build": "bun build ./src/server.ts --outdir ./dist --target bun",
    "inngest": "npx --ignore-scripts=false inngest-cli@latest dev -u http://localhost:8000/api/inngest",
    "typecheck": "tsc --noEmit --project tsconfig.typecheck.json",
    "start": "bun with-env dist/server.js",
    "dev": "bun with-env --watch src/server.ts",
    "with-env": "bun run --env-file ../../.env"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.49",
    "@calls/ai": "workspace:*",
    "@calls/asr": "workspace:*",
    "@calls/config": "workspace:*",
    "@calls/db": "workspace:*",
    "@calls/emails": "workspace:*",
    "@calls/lib": "workspace:*",
    "@calls/shared": "workspace:*",
    "@calls/telegram-bot": "workspace:*",
    "ai": "^6.0.142",
    "basic-ftp": "^5.2.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "hono": "4.12.9",
    "inngest": "4.1.0",
    "music-metadata": "^11.12.3",
    "ssh2-sftp-client": "12.1.1",
    "undici": "^7.24.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@calls/tsconfig": "workspace:*",
    "@types/bun": "^1.3.11",
    "biome": "^0.3.3",
    "typescript": "6.0.2"
  }
}
