{
  "name": "@calls/auth",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./env": "./env.ts"
  },
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf *.tsbuildinfo .turbo",
    "dev": "bun with-env generate",
    "generate": "bun -b run src/index.ts",
    "typecheck": "tsc --noEmit",
    "with-env": "bun run --env-file ../../.env"
  },
  "dependencies": {
    "@calls/config": "workspace:*",
    "@calls/db": "workspace:*",
    "better-auth": "1.5.5",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@calls/tsconfig": "workspace:*",
    "typescript": "5.9.3"
  }
}
