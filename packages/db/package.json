{
  "name": "@calls/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./client": {
      "default": "./src/client.ts"
    },
    "./client.ws": {
      "default": "./src/client.ws.ts"
    },
    "./schema": {
      "default": "./src/schema/index.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf *.tsbuildinfo .turbo",
    "db:generate": "bunx drizzle-kit generate",
    "migrate:create": "bun with-env drizzle-kit generate",
    "migrate": "bun with-env drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "db:setup": "bun with-env src/scripts/setup-db.ts",
    "dev": "bun with-env src/index.ts",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "bun run --env-file ../../.env"
  },
  "dependencies": {
    "@calls/config": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "@vercel/postgres": "0.10.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "0.45.1",
    "pg": "^8.13.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@calls/tsconfig": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.9",
    "typescript": "5.9.3"
  }
}
