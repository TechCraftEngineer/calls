{
  "name": "@calls/db",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./client": {
      "default": "./src/client.ts"
    },
    "./client.ws": {
      "default": "./src/client.ws.ts"
    },
    "./schema": {
      "default": "./src/schema/index.ts"
    },
    "./shared": {
      "default": "./src/shared.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf *.tsbuildinfo .turbo",
    "db:generate": "bunx drizzle-kit generate",
    "migrate:create": "bun with-env drizzle-kit generate",
    "migrate": "bun with-env src/scripts/migrate.ts",
    "db:push": "bunx drizzle-kit push",
    "db:push:ci": "bunx drizzle-kit push --force",
    "db:studio": "bunx drizzle-kit studio",
    "db:setup": "bun with-env src/scripts/setup-db.ts",
    "db:drop": "bun with-env src/scripts/drop-schema.ts",
    "db:reset": "bun with-env src/scripts/drop-schema.ts && bun run db:setup && bun run migrate",
    "dev": "bun with-env src/index.ts",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false",
    "with-env": "bun run --env-file ../../.env"
  },
  "dependencies": {
    "@calls/config": "workspace:*",
    "@calls/lib": "workspace:*",
    "@calls/shared": "workspace:*",
    "@neondatabase/serverless": "1.0.2",
    "@vercel/postgres": "0.10.0",
    "drizzle-orm": "0.45.2",
    "pg": "^8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@calls/tsconfig": "workspace:*",
    "@types/bun": "^1.3.11",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "6.0.2"
  }
}
