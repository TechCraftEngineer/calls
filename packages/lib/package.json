    "@aws-sdk/s3-request-presigner": "3.1023.0",
    "@calls/config": "workspace:*"
  },
  "devDependencies": {
    "@calls/tsconfig": "workspace:*",
    "tsdown": "^0.21.8",
    "typescript": "6.0.2"
