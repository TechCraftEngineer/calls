{
  "name": "@calls/config",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "clean": "rm -rf *.tsbuildinfo .turbo dist",
    "dev": "bun with-env src/index.ts",
    "typecheck": "tsc --noEmit",
    "with-env": "bun run --env-file ../../.env"
  },
  "dependencies": {
    "@t3-oss/env-core": "0.13.10",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@calls/tsconfig": "workspace:*",
    "tsdown": "^0.21.2",
    "typescript": "5.9.3"
  }
}
