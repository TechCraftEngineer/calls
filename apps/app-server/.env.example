# Backend Environment Variables
# Скопируйте этот файл в .env и заполните значения

# Порт сервера (по умолчанию 7000)
# PORT=7000

# Better Auth Configuration
# Важно: должен указывать на URL этого сервера (не на фронтенд!)
# чтобы избежать ERR_TOO_MANY_REDIRECTS
BETTER_AUTH_URL=http://localhost:7000

# Database (используется тот же PostgreSQL, что и для фронтенда)
POSTGRES_URL=postgres://postgres.[USERNAME]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?workaround=supabase-pooler.vercel

# CORS Origins (фронтенд URL)
CORS_ORIGINS=http://localhost:3000

# Better Auth Secret (тот же ключ, что и в корневом .env)
BETTER_AUTH_SECRET=supersecret

# Inngest (опционально)
# INNGEST_SIGNING_KEY=
# INNGEST_EVENT_KEY=

# Google OAuth (из корневого .env)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Email Sandbox (опционально)
EMAIL_SANDBOX_ENABLED=true
EMAIL_SANDBOX_HOST=localhost

# Webhook Rate Limiting (опционально)
# WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
# WEBHOOK_RATE_LIMIT_MAX_REQUESTS=30
