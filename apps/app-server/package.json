{
  "name": "@calls/app-server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --watch ../../packages/api/src --watch ../../packages/db/src --watch ../../packages/jobs/src --ext ts,tsx,json --exec \"bun with-env src/index.ts\"",
    "start": "bun with-env dist/index.js",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "with-env": "bun run --env-file ../../.env"
  },
  "dependencies": {
    "@calls/ai": "workspace:*",
    "@calls/api": "workspace:*",
    "@calls/config": "workspace:*",
    "@calls/db": "workspace:*",
    "@calls/emails": "workspace:*",
    "@calls/jobs": "workspace:*",
    "@calls/lib": "workspace:*",
    "@calls/telegram-bot": "workspace:*",
    "@calls/validators": "workspace:*",
    "@orpc/server": "^1.13.14",
    "better-auth": "1.6.4",
    "grammy": "1.42.0",
    "hono": "4.12.14"
  },
  "devDependencies": {
    "@calls/tsconfig": "workspace:*",
    "nodemon": "^3.1.14",
    "typescript": "6.0.2"
  }
}
