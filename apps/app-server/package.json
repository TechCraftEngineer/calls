{
  "name": "@calls/app-server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun with-env src/index.ts",
    "start": "bun with-env dist/index.js",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "typecheck": "tsc --noEmit",
    "with-env": "bun run --env-file ../../.env"
  },
  "dependencies": {
    "@calls/api": "workspace:*",
    "@calls/config": "workspace:*",
    "@calls/db": "workspace:*",
    "@calls/emails": "workspace:*",
    "@calls/jobs": "workspace:*",
    "@calls/telegram-bot": "workspace:*",
    "@orpc/server": "^1.13.7",
    "better-auth": "1.5.5",
    "grammy": "^1.38.0",
    "hono": "4.12.8"
  },
  "devDependencies": {
    "@calls/tsconfig": "workspace:*",
    "typescript": "5.9.3"
  }
}
