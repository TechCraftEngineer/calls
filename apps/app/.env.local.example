# Frontend Environment Variables
# Скопируйте этот файл в .env.local и заполните значения

# API URL для подключения к бэкенду
NEXT_PUBLIC_API_URL=http://localhost:7000

# Better Auth Configuration
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:7000

# Google OAuth (опционально, для отключения кнопки: NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false)
# Ключи задаются в корневом .env (AUTH_GOOGLE_ID, AUTH_GOOGLE_SECRET)
# NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false

# Development/Production
NODE_ENV=development

# Для production:
# NEXT_PUBLIC_API_URL=https://your-domain.com
# NEXT_PUBLIC_BETTER_AUTH_URL=https://your-domain.com
