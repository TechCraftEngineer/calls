## Валидация и схемы

### Использование Zod v4

```typescript
import { z } from "zod";
import { workspaceIdSchema } from "@qbs-autonaim/validators";

// Переиспользование схем из пакета validators
export const get = protectedProcedure
  .input(z.object({ 
    id: workspaceIdSchema 
  }))
  .handler(async ({ input, context }) => {
    // ...
  });

// Inline схемы для простых случаев
export const update = protectedProcedure
  .input(z.object({
    id: z.string(),
    name: z.string().min(1).max(100),
    description: z.string().optional(),
  }))
  .handler(async ({ input, context }) => {
    // ...
  });
```

### Переиспользование схем

Храните общие схемы в `@qbs-autonaim/validators`:

```typescript
// packages/validators/src/workspace.ts
export const workspaceIdSchema = z.string().regex(/^ws_[0-9a-fA-F]{32}$/, "Invalid workspace ID format");
export const workspaceSlugSchema = z.string().min(3).max(50);

// packages/api/src/routers/workspace/get.ts
import { workspaceIdSchema } from "@qbs-autonaim/validators";
```

## Обработка ошибок

### Стандартные коды ошибок

```typescript
import { ORPCError } from "@orpc/server";

// NOT_FOUND - ресурс не найден
if (!workspace) {
  throw new ORPCError("NOT_FOUND", {
    message: "Workspace не найден",
  });
}

// FORBIDDEN - нет доступа
if (!hasAccess) {
  throw new ORPCError("FORBIDDEN", {
    message: "Нет доступа к workspace",
  });
}

// BAD_REQUEST - некорректные данные
if (invalidData) {
  throw new ORPCError("BAD_REQUEST", {
    message: "Некорректные данные",
  });
}

// UNAUTHORIZED - не авторизован (обрабатывается автоматически в protectedProcedure)
// INTERNAL_SERVER_ERROR - внутренняя ошибка (по умолчанию)
```

### Type-safe ошибки и ORPCError.data

В orpc.ts настроены типизированные ошибки через `.errors()` — клиент получает автокомплит для `error.data`.

**TOO_MANY_REQUESTS** — передавайте `retryAfter` в data (секунды):

```typescript
throw new ORPCError("TOO_MANY_REQUESTS", {
  message: "Превышен лимит запросов",
  data: { retryAfter: 60 },
});
```

**ВАЖНО:** `ORPCError.data` передаётся клиенту. Не включайте чувствительные данные (userId, tokens, stack traces).

См. https://orpc.dev/docs/error-handling

### Проверка доступа

```typescript
export const get = protectedProcedure
  .input(z.object({ id: workspaceIdSchema }))
  .handler(async ({ input, context }) => {
    // 1. Проверка существования
    const workspace = await context.workspaceRepository.findById(input.id);
    if (!workspace) {
      throw new ORPCError(
        code: "NOT_FOUND",
        message: "Workspace не найден",
      });
    }

    // 2. Проверка доступа
    const hasAccess = await context.workspaceRepository.checkAccess(
      input.id,
      context.session.user.id,
    );
    if (!hasAccess) {
      throw new ORPCError(
        code: "FORBIDDEN",
        message: "Нет доступа к workspace",
      });
    }

    return workspace;
  });
```

