# Since .env is gitignored, you can use .env.example to build a new `.env` file when you clone the repo.
# Keep this file up-to-date when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any secrets in it.
# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# The database URL is used to connect to your Supabase database.
POSTGRES_URL="postgres://postgres.[USERNAME]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?workaround=supabase-pooler.vercel"

# App URL (used in emails and metadata)
APP_URL=http://localhost:3000

# App Configuration
NEXT_PUBLIC_APP_NAME="Acme Inc."
NEXT_PUBLIC_APP_SHORT_NAME="Acme"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# You can generate the secret via 'openssl rand -base64 32' on Unix
# @see https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET='supersecret'

# Шифрование паролей интеграций (Megafon FTP и др.) в БД.
# Если не задан — используется BETTER_AUTH_SECRET.
# Рекомендуется задать отдельный ключ: openssl rand -base64 32
# ENCRYPTION_KEY=

# Preconfigured Google OAuth provider, works out-of-the-box
# @see https://www.better-auth.com/docs/authentication/google
AUTH_GOOGLE_ID=''
AUTH_GOOGLE_SECRET=''
EMAIL_SANDBOX_ENABLED=true
EMAIL_SANDBOX_HOST=localhost

# AI провайдер: openai | openrouter | deepseek
# AI_PROVIDER=openai
# Модель по умолчанию (зависит от провайдера: gpt-4o-mini, openai/gpt-4o-mini, deepseek-chat)
# AI_MODEL=gpt-4o-mini

# API ключи (нужен ключ для выбранного провайдера)
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
# AI_RECOMMENDATIONS_MODEL=openai/gpt-4o-mini

# ASR (распознавание речи) — для транскрибации звонков
# Минимум один провайдер обязателен для pipeline
# AssemblyAI: https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=
# Yandex SpeechKit: https://yandex.cloud/docs/speechkit/
YANDEX_SPEECHKIT_API_KEY=
# OPENAI_API_KEY — для LLM-нормализации текста (орфография, пунктуация)

# Megafon PBX FTP (для cron-задачи загрузки записей)
MEGAFON_FTP_HOST=records.megapbx.ru
MEGAFON_FTP_USER=your-megafon-ftp-user
MEGAFON_FTP_PASSWORD=your-megafon-ftp-password

# MinIO / S3-совместимое хранилище (для файлов и записей звонков)
# Локальный MinIO из docker-compose: minio / password, bucket: files.acme.com
# Yandex Object Storage: https://storage.yandexcloud.net, region: ru-central1
# Для Yandex SpeechKit ASR: статический ключ должен иметь права чтения объектов (storage.editor)
AWS_S3_ENDPOINT=http://localhost:9002
AWS_S3_FORCE_PATH_STYLE=true
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=password
AWS_S3_BUCKET=files.acme.com
# AWS_REGION=us-east-1

# Inngest (cron и фоновые задачи)
# INNGEST_SIGNING_KEY=signkey-prod-...  # из Inngest dashboard
# INNGEST_EVENT_KEY=                        # опционально, для отправки событий

# Webhook Telegram использует APP_URL / NEXT_PUBLIC_APP_URL (тот же URL, что и приложение)